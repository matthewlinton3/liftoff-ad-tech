# Build stage
FROM golang:1.25-alpine AS builder
WORKDIR /build

COPY exchange/go.mod ./
RUN go mod download 2>/dev/null || true

COPY exchange/ ./
RUN CGO_ENABLED=0 go build -o exchange .

# Run stage
FROM alpine:3.19
WORKDIR /app

RUN apk add --no-cache ca-certificates

COPY --from=builder /build/exchange .

EXPOSE 3000

CMD ["./exchange"]
